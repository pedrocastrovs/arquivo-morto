# =============================================================================
# Arquivo Morto — variáveis de ambiente (padrão Supabase + Next.js 2025+)
# =============================================================================
# Documentação: https://supabase.com/docs/guides/getting-started/quickstarts/nextjs
#
# 1. Dashboard → Connect (Next.js) ou Settings → API Keys
# 2. Preencha .env.local com os valores do seu projeto
# 3. Nunca commite .env.local (já está no .gitignore)
# =============================================================================

# --- Supabase (cliente — browser e Server Components) ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua_publishable_key_aqui

# --- Supabase (servidor — Server Actions, admin; NÃO expor no client) ---
# Novo formato: sb_secret_... (API Keys → Secret key)
# Legado até ~2026: service_role JWT (aba Legacy API Keys)
SUPABASE_SECRET_KEY=sua_secret_key_aqui

# --- App (opcional; redirects de login) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Ambiente ---
NODE_ENV=development

# -----------------------------------------------------------------------------
# Legado (opcional — só se o projeto ainda não tiver publishable/secret keys)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_ANON_KEY=   # equivalente à PUBLISHABLE_KEY
# SUPABASE_SERVICE_ROLE_KEY=       # equivalente à SECRET_KEY
